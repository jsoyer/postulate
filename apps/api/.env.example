# cv-api configuration

# Path to the local CV project (required)
CV_PATH=/path/to/your/CV

# Server port (default: 3001)
PORT=3001

# Authentication secret for JWT signing (min 32 chars)
AUTH_SECRET=your_super_secret_key_minimum_32_characters

# Web login credentials
AUTH_USERNAME=jerome
AUTH_PASSWORD=your_password

# Optional TOTP secret for 2FA
AUTH_TOTP_SECRET=

# Comma-separated list of API keys for TUI clients (editor role — read + write)
# Generate with: openssl rand -base64 32
API_KEYS=key1,key2

# Comma-separated list of read-only API keys (viewer role — read only)
# Keys listed here cannot create/modify applications, run actions, or change settings.
# If omitted, all API_KEYS are granted editor access.
# Generate with: openssl rand -base64 32
VIEWER_API_KEYS=

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Targets allowlist file path (default: config/targets.yml)
TARGETS_FILE=config/targets.yml

# ── cv-runner (execution backend) ────────────────────────────────────────────

# URL of the cv-runner service (default matches docker-compose internal network)
RUNNER_URL=http://cv-runner:3002

# Shared secret between cv-api and cv-runner (min 32 chars)
# Generate with: openssl rand -base64 32
RUNNER_SECRET=your_runner_secret_minimum_32_characters

# Max concurrent make jobs handled by cv-runner (default: 3)
MAX_CONCURRENT=3

# ── AI providers (forwarded to Make targets by cv-runner) ─────────────────────
# Only set the providers you use. All are optional.

# Google Gemini (default provider for `make tailor`)
# Generate at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic Claude (`make tailor AI=claude`)
# Generate at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (`make tailor AI=openai`)
# Generate at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Mistral (`make tailor AI=mistral`)
# Generate at: https://console.mistral.ai/
MISTRAL_API_KEY=

# Ollama — local LLM, no key required (`make tailor AI=ollama`)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Notifications (forwarded to `make notify` / `make digest`) ────────────────

SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── LinkedIn (`make linkedin`, `make linkedin-profile`) ───────────────────────

LINKEDIN_ACCESS_TOKEN=

# ── Notion (`make notion`, `make notion-pull`, `make notion-push`) ────────────

NOTION_TOKEN=
NOTION_DATABASE_ID=
