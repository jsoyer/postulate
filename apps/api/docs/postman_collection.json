{
  "info": {
    "_postman_id": "cv-api-collection-v1",
    "name": "cv-api",
    "description": "Complete API collection for the CV management system. Set the `apiKey` collection variable before sending requests. After login the test script will populate `jwtToken` automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "apiKey",
      "value": "your-api-key-here",
      "type": "string"
    },
    {
      "key": "jwtToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "appName",
      "value": "2024-03-example-company",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set(\"jwtToken\", json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"changeme\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Validates credentials and sets a JWT session cookie. The test script saves the token to the `jwtToken` collection variable."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Clears the session cookie."
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "List applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/applications?status=applied&sort=created_at&order=desc&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications"],
              "query": [
                {
                  "key": "status",
                  "value": "applied",
                  "description": "Filter by status"
                },
                {
                  "key": "company",
                  "value": "",
                  "description": "Filter by company name substring",
                  "disabled": true
                },
                {
                  "key": "sort",
                  "value": "created_at"
                },
                {
                  "key": "order",
                  "value": "desc"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "cursor",
                  "value": "",
                  "description": "Pagination cursor from X-Next-Cursor header",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Create application",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company\": \"Example Company\",\n  \"position\": \"Senior Software Engineer\",\n  \"url\": \"https://example.com/jobs/123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/applications",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications"]
            }
          }
        },
        {
          "name": "Get application",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/applications/{{appName}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications", "{{appName}}"]
            }
          }
        },
        {
          "name": "Update application",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"interviewing\",\n  \"followup_date\": \"2024-04-01\",\n  \"deadline\": \"2024-04-15\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/applications/{{appName}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications", "{{appName}}"]
            }
          }
        },
        {
          "name": "Bulk update applications",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"names\": [\"{{appName}}\", \"2024-02-another-corp\"],\n  \"update\": {\n    \"status\": \"rejected\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/applications",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications"]
            }
          }
        },
        {
          "name": "Export applications (JSON)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/applications/export?format=json",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications", "export"],
              "query": [
                {
                  "key": "format",
                  "value": "json"
                }
              ]
            }
          }
        },
        {
          "name": "Export applications (CSV)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/applications/export?format=csv",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications", "export"],
              "query": [
                {
                  "key": "format",
                  "value": "csv"
                }
              ]
            }
          }
        }
      ]
    },
