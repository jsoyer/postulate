# cv-tui-rs (Ratatui, rustls)
#
# Talks to cv-api over HTTP/WS using the X-API-Key header.
# No secret is committed; provide these at runtime via your shell/env.

# Base URL of the cv-api hub
CV_API_URL=http://localhost:3001

# API key issued by cv-api (X-API-Key header)
CV_API_KEY=your-api-key-here

# Request timeout in seconds (optional)
CV_TIMEOUT=30
