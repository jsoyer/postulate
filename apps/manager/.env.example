# cv-api backend URL (required)
CV_API_URL=http://localhost:8000

# cv-api authentication key (required)
CV_API_KEY=your-api-key-here

# Path to CV project directory (optional, legacy)
CV_PATH=/path/to/your/cv/project

# Auth configuration
AUTH_SECRET=change-this-to-a-random-32-char-string
AUTH_USERNAME=your-username
AUTH_PASSWORD=your-password
AUTH_TOTP_SECRET=

# WebAuthn domain (default: localhost)
AUTH_DOMAIN=localhost
