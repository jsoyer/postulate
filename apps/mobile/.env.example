# cv-mobile (Expo / React Native)
#
# Runtime configuration is entered in-app and stored via expo-secure-store
# (keys: cv_api_url, cv_api_key). There are no build-time secrets.
#
# Optionally, a public default API URL can be injected at build time.
# EXPO_PUBLIC_* vars are embedded in the client bundle — NEVER put a secret here.
EXPO_PUBLIC_API_URL=http://localhost:3001
