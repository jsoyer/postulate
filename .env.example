# Copy this file to .env and fill in your keys
# cp .env.example .env
#
# All variables are optional — only set what you need.

# AI Tailoring — set the key for your chosen provider (make tailor AI=...)
GEMINI_API_KEY=your-key-here           # https://aistudio.google.com/apikey  (default)
# ANTHROPIC_API_KEY=your-key-here     # https://console.anthropic.com/       (AI=claude)
# OPENAI_API_KEY=your-key-here        # https://platform.openai.com/api-keys (AI=openai)
# MISTRAL_API_KEY=your-key-here       # https://console.mistral.ai/          (AI=mistral)
# OLLAMA_HOST=http://localhost:11434   # local Ollama — no key needed         (AI=ollama)
# OLLAMA_MODEL=llama3

# LinkedIn sync (make linkedin)
# LINKEDIN_ACCESS_TOKEN=your-token-here
# LINKEDIN_PUSH=false

# Notion sync (make notion-sync, make notify)
# NOTION_TOKEN=secret_...              # https://www.notion.so/my-integrations
# NOTION_DATABASE_ID=your-db-id-here  # 32-char hex from database URL

# Notifications — used by make notify, make deadline-alert, make digest
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=123456789
