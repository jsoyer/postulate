# Generated files
*.pdf
*.tex

# Track docs assets and PDFs
!docs/
!docs/assets/
!docs/assets/**
!docs/*.pdf

# Environment variables (API keys)
.env

# Application-specific content (private)
applications/

# macOS
.DS_Store

