__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
venv/
.venv/

# Editor temp files
.*sw[op]
*~

# runtime RSS discovery cache (not for VCS)
scripts/.rss-cache.json
