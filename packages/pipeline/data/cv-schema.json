{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CV YAML Schema",
  "description": "Validates data/cv.yml structure for the awesome-cv render pipeline",
  "type": "object",
  "required": ["personal", "profile", "skills", "experience", "education"],
  "additionalProperties": false,
  "properties": {
    "personal": {
      "type": "object",
      "required": ["first_name", "last_name", "position", "email"],
      "properties": {
        "first_name": { "type": "string", "minLength": 1 },
        "last_name": { "type": "string", "minLength": 1 },
        "position": { "type": "string", "minLength": 1 },
        "address": { "type": "string" },
        "mobile": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "linkedin": { "type": "string" },
        "github": { "type": "string" },
        "homepage": { "type": "string" }
      }
    },
    "profile": {
      "type": "string",
      "minLength": 50,
      "not": {
        "pattern": "\\[.*\\]"
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["category", "items"],
        "properties": {
          "category": { "type": "string", "minLength": 1 },
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "key_wins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "text"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 }
        }
      }
    },
    "experience": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "company", "dates"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "company": { "type": "string", "minLength": 1 },
          "location": { "type": "string" },
          "dates": {
            "type": "string",
            "pattern": ".*--.*"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["text"],
              "properties": {
                "label": { "type": "string" },
                "text": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "early_career": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "company", "dates"],
        "properties": {
          "title": { "type": "string" },
          "company": { "type": "string" },
          "location": { "type": "string" },
          "dates": { "type": "string" }
        }
      }
    },
    "education": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["degree", "school", "dates"],
        "properties": {
          "degree": { "type": "string" },
          "school": { "type": "string" },
          "location": { "type": "string" },
          "dates": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "certifications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "date"],
        "properties": {
          "name": { "type": "string" },
          "institution": { "type": "string" },
          "date": { "type": "string" }
        }
      }
    },
    "awards": { "type": "string" },
    "publications": { "type": "string" },
    "languages": {
      "type": "array",
      "items": { "type": "string" }
    },
    "interests": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
